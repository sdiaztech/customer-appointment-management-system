{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Run Appointment Management System",
      "request": "launch",
      "mainClass": "main.Main",
      "cwd": "${workspaceFolder}",
      "sourcePaths": [
        "app/src"
      ],
      "classPaths": [
        "app/src",
        "lib/mysql-connector-j-8.0.33.jar"
      ],
      "vmArgs": "--module-path lib/javafx --add-modules javafx.controls,javafx.fxml",
      "console": "integratedTerminal"
    }
  ]
}